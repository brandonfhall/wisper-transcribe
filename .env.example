# wisper-transcribe — Docker environment
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# HuggingFace token (REQUIRED for speaker diarization)
# Free token at https://huggingface.co/settings/tokens
# You must also accept the pyannote model terms at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# ── Cloud LLM providers (optional — leave blank to use local Ollama) ─────────
# Uncomment and fill in the key for the provider you want to use.
# These are never needed for transcription; only for wisper refine / summarize.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
